<!DOCTYPE html>
<html lang="es">

<head>
    <%- include ('partials/head') %>
    <link rel="stylesheet" href="/css/upload-forma-comprar.css">
    <script type="module" src="/scripts/upload-forma-comprar.js"></script>
    <title>Subir forma de comprar - Store99</title>
</head>

<body>
    <%- include ('partials/header') %>
    <main>
        <div class="upload-container">
            <h1>Reemplazar forma de comprar</h1>
            <p id="msg" class="msg"></p>
            <form id="upload-form">
                <label for="pdf">Seleccionar PDF</label>
                <input type="file" id="pdf" name="pdf" accept="application/pdf" required>
                <button type="submit" id="submit-btn">Subir PDF</button>
            </form>
        </div>
    </main>
    <%- include ('partials/footer') %>
</body>

</html>
