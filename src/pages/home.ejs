<!DOCTYPE html>
<html lang="en">

<head>
    <%- include ('partials/head') %>
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/models-list.css">
    <script type="module" src="/scripts/home.js"></script>
</head>

<body>
    <%- include ('partials/header') %>
  <main>
<div class="carousel" id="heroCarousel" aria-roledescription="carousel" aria-label="Destacados">
  <div class="slides" id="heroSlides" aria-live="polite">
    <div class="slide" role="group" aria-label="Slide 1 de 3">
      <picture>
        <source media="(max-width: 767px)" srcset="/assets/banner1_mobile.jpg">
        <img src="/assets/banner1.png" alt="Zapatillas exclusivas Nike" loading="eager" />
      </picture>
    </div>
    <div class="slide" role="group" aria-label="Slide 2 de 3">
      <picture>
        <source media="(max-width: 767px)" srcset="/assets/img-2-slider.png">
        <img src="/assets/banner2.png" alt="Adidas Harden Vol. 8" loading="lazy" />
      </picture>
    </div>
    <div class="slide" role="group" aria-label="Slide 3 de 3">
      <img src="/assets/banner3.png" alt="Li-Ning Way of Wade 11" loading="lazy" />
    </div>
  </div>
  <div class="dots" id="heroDots" aria-hidden="false"></div>
</div>


</section>

    <!-- VENTAJAS / VALUE PROPS -->
    <section class="value-props">
      <div class="props-container props-grid">
        <article class="prop">
          <div class="prop-ico" aria-hidden><img class="home-icon" src="/assets/2.png" alt=""></div>
          <h3>Autenticidad garantizada</h3>
          <p>Trabajamos con retailers oficiales y chequeos de calidad en origen en USA.</p>
        </article>
        <article class="prop">
          <div class="prop-ico" aria-hidden><img class="home-icon" src="/assets/1.png" alt=""></div>
          <h3>Envío a todo el país</h3>
          <p>Seguimiento puerta a puerta y embalaje protegido.</p>
        </article>
        <article class="prop">
          <div class="prop-ico" aria-hidden><img class="home-icon" src="/assets/3.png" alt=""></div>
          <h3>Asesoría personalizada</h3>
          <p>Te ayudamos a elegir talla y silueta según tu juego.</p>
        </article>
      </div>
    </section>
    
    <section class="brands-slider">
      <button class="brands-arrow brands-prev" aria-label="Anterior">
        <img src="/assets/arrow-right.png" alt="" class="arrow-flipped">
      </button>
      <div class="brands-viewport">
        <div class="brands-track" id="brandsTrack">
          <div class="brand-item"><img src="/assets/nike-logo.png" alt="Nike"></div>
          <div class="brand-item"><img src="/assets/adidas-logo.png" alt="Adidas"></div>
          <div class="brand-item"><img src="/assets/under-armour-logo.png" alt="Under Armour"></div>
          <div class="brand-item"><img src="/assets/puma-logo.png" alt="Puma"></div>
          <div class="brand-item"><img src="/assets/anta-logo.png" alt="Anta"></div>
          <div class="brand-item"><img src="/assets/lining-logo.png" alt="Li-Ning"></div>
        </div>
      </div>
      <button class="brands-arrow brands-next" aria-label="Siguiente">
        <img src="/assets/arrow-right.png" alt="">
      </button>
    </section>

    <section class="shoe-grid latest" id="shoe-list">
      <p class="latest-label">Últimas publicadas</p>
    </section>
   
    <section class="novedades">
      <h2 class="novedades-title">Novedades</h2>

      <article class="novedad-card novedad-dark">
        <div class="novedad-img-wrap">
          <img src="/assets/ja3byyou.png" alt="Nike JA 3 By You">
        </div>
        <div class="novedad-body">
          <p class="novedad-label">Nike By You</p>
          <h3 class="novedad-name">JA 3 By You</h3>
          <p class="novedad-desc">
            La zapatilla de Ja Morant, ahora con tu firma. Elegí cada color, cada material, cada detalle — desde los cordones hasta la suela. Una JA 3 que no va a tener nadie más.
          </p>
          <a class="novedad-btn" href="https://wa.me/<%= locals.whatsappNumber || '' %>?text=<%= encodeURIComponent('Hola! Consulto por la JA 3 By You') %>" target="_blank" rel="noopener">
            Consultar por WhatsApp
          </a>
        </div>
      </article>

      <article class="novedad-card novedad-light">
        <div class="novedad-img-wrap">
          <img src="/assets/sabrina3byyou.png" alt="Nike Sabrina 3 By You">
        </div>
        <div class="novedad-body">
          <p class="novedad-label">Nike By You</p>
          <h3 class="novedad-name">Sabrina 3 By You</h3>
          <p class="novedad-desc">
            La firma de Sabrina Ionescu, personalizable de punta a punta. Combiná la base, el Swoosh y los detalles a tu gusto. Hecha para la cancha, diseñada por vos.
          </p>
          <a class="novedad-btn" href="https://wa.me/<%= locals.whatsappNumber || '' %>?text=<%= encodeURIComponent('Hola! Consulto por la Sabrina 3 By You') %>" target="_blank" rel="noopener">
            Consultar por WhatsApp
          </a>
        </div>
      </article>
    </section>

    <%- include ('partials/footer') %>

</body>
</html>