<!DOCTYPE html>
<html lang="en">

<head>
    <%- include ('partials/head') %>
    <link rel="stylesheet" href="/css/model-detail.css">
    <script type="module" src="/scripts/model-detail.js"></script>
</head>

<body>
    <%- include ('partials/header') %>
    <main class="main-container">
        <!-- MOBILE CAROUSEL (solo se muestra <900px) -->
        <div class="mobile-carousel" id="mobileCarousel">
          <div class="mobile-slider" id="mobileSlider" aria-live="polite">
            <% model.files.forEach((file, index) => { %>
              <div class="mobile-slide" role="group" aria-roledescription="slide" aria-label="<%= index + 1 %> de <%= model.files.length %>">
                <img src="<%= file.key %>" alt="Imagen <%= index + 1 %>">
              </div>
            <% }) %>
          </div>
          <div class="dots" id="dots"></div>
        </div>

          <!-- DESKTOP (tu layout actual “tipo Nike”) -->
          <div class="carousel-container">
            <div class="thumbnail-column" id="thumbnailColumn">
              <% model.files.forEach((file, index) => { %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <img src="<%= file.key %>" alt="Miniatura" data-index="<%= index %>">
                </div>
              <% }) %>
            </div>

        <div class="main-image">
          <img id="mainImage" src="<%= model.files[0]?.key %>" alt="Imagen principal">
        </div>
  </div>

      <section class="product-info">
        <div class="product-props">
          <h2 class="brand"><%= model.brand.name %></h2>
          <h1 class="model-name"><%= model.name.toUpperCase() %></h1>
          <p class="color"><%= model.color.charAt(0).toUpperCase() + model.color.slice(1) %></p>
        </div>
      
        <% if (model.stocks && model.stocks.length > 0) { %>
        <div class="sizes-section">
          <p class="sizes-label">Talles disponibles entrega inmediata</p>
          <div class="sizes-grid">
            <% model.stocks.forEach(size => { %>
              <span class="size-tag"><%= size.us_size %></span>
            <% }) %>
          </div>
        </div>
        <% } %>

        <p class="delivery-time">⏱ Si no hay stock, demora 25-30 días por encargue</p>

        <ul class="copy" type="none">
          <li><i class='bx bx-square'></i> Consultar otros talles por encargue</li>
          <li><i class='bx bx-square'></i> Distintas formas de pago</li>
          <li><i class='bx bx-square'></i> Envíos a todo el país</li>
          <li><i class='bx bx-square'></i> Chequeá las reviews <a href="https://weartesters.com/" target="_blank" rel="noopener"><img class="wear" src="/assets/wear.png" alt="Wear Testers"></a></li>
        </ul>

        <a class="whatsapp-btn" target="_blank" rel="noopener"
          href="https://wa.me/<%= whatsappNumber %>?text=<%= encodeURIComponent('Hola! Consulto por ' + model.name.toUpperCase() + ' ' + model.color) %>">
          <i class='bx bxl-whatsapp'></i> Consultar por WhatsApp
        </a>

      </section>
    </main>

   
    <% if(locals.isLogged) {  %>
       <section class="actions-buttons">
            <a class="action-btn" href="/editar-stock?modelId=<%= model.id %>">Actualizar stock</a>
            <button class="action-btn delete-btn" data-model-id="<%= model.id %>" data-category-id="<%= model.categories && model.categories[0] ? model.categories[0].id : '1' %>">Eliminar</button>
        </section>
    <div id="deleteModal" class="modal-overlay">
      <div class="modal-content">
        <h3>¿Estás seguro de eliminarlo?</h3>
        <div class="modal-actions">
          <button id="confirmDelete" class="action-btn delete-btn">Aceptar</button>
          <button id="cancelDelete" class="action-btn">Cancelar</button>
        </div>
      </div>
    </div>
    <%  } %>
    
   
    <%- include ('partials/footer') %>

</body>
</html>